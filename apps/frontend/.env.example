# Supabase Database & Auth Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres?connection_limit=1"
DIRECT_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# Upstash Serverless Redis Configuration
REDIS_MODE="standalone" # Options: standalone | cluster | sentinel
REDIS_URL="rediss://:your-password@your-endpoint.upstash.io:6379"

# API Keys for LLM Completions
GEMINI_API_KEY="AIzaSyYourGoogleStudioKeyHere"
OPENAI_API_KEY="sk-proj-YourOpenAIKeyHere"
