datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  name               String?
  avatarUrl          String?
  passwordHash       String?
  githubOauthToken   String?
  billingTier        String         @default("free")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organizationsOwned Organization[] @relation("OrgOwner")
  memberships        OrgMember[]
  conversations      Conversation[]
  apiKeys            ApiKey[]
  fileLocks          FileLock[]

  @@map("users")
}

model Organization {
  id        String      @id @default(uuid())
  name      String
  ownerId   String
  owner     User        @relation("OrgOwner", fields: [ownerId], references: [id])
  createdAt DateTime    @default(now())
  members   OrgMember[]
  projects  Project[]

  @@map("organizations")
}

model OrgMember {
  id               String       @id @default(uuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             String       @default("DEVELOPER")
  joinedAt         DateTime     @default(now())
  gpuTokenLimit    Int          @default(100000)
  sandboxTimeLimit Int          @default(3600)
  gpuTokenUsage    Int          @default(0)
  sandboxTimeUsage Int          @default(0)

  @@unique([orgId, userId])
  @@map("org_members")
}

model Project {
  id                 String         @id @default(uuid())
  orgId              String
  org                Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name               String
  githubRepoUrl      String
  defaultBranch      String         @default("main")
  lastIndexedCommit  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  conversations      Conversation[]
  fileIndexes        FileIndex[]
  fileLocks          FileLock[]

  @@map("projects")
}

model Conversation {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title       String
  activeModel String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]

  @@map("conversations")
}

model Message {
  id               String       @id @default(uuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderRole       String
  content          String
  toolCalls        String?
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  createdAt        DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash    String    @unique
  displayKey String
  label      String
  scopes     String
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

model FileIndex {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filePath       String
  fileSha        String
  fileSizeBytes  Int
  language       String
  embedding      String?  // We can store embedding vectors as serialized strings, or JSON, to bypass direct pgvector Prisma types cleanly
  updatedAt      DateTime @updatedAt

  @@map("file_index")
}

model FileLock {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filePath  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName  String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([projectId, filePath])
  @@map("file_locks")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userEmail String?
  action    String
  target    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
